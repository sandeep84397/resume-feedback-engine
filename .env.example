# LLM (bring your own; OpenAI-compatible endpoint)
RFE_LLM_BASE_URL=http://localhost:11434/v1
RFE_LLM_MODEL=llama3
RFE_LLM_API_KEY=

# Persistence
RFE_DB_PATH=/app/data/rfe.db

# Auth — comma-separated key:role pairs (roles: admin, recruiter, viewer).
# A bare key (no :role) is treated as admin (backward compatible with Phase 2).
# Example: RFE_API_KEYS="adminkey:admin,reckey:recruiter,viewkey:viewer"
# Generate keys with: openssl rand -hex 32
RFE_API_KEYS=

# Audit log
RFE_AUDIT_LOG=/app/data/audit.jsonl

# Feedback-page tokens
RFE_TOKEN_SECRET=
RFE_TOKEN_TTL_HOURS=168

# SMTP delivery
RFE_SMTP_HOST=
RFE_SMTP_PORT=587
RFE_SMTP_USER=
RFE_SMTP_PASS=
RFE_SMTP_FROM=no-reply@example.com

# Webhook delivery (optional)
RFE_WEBHOOK_URL=
RFE_WEBHOOK_SECRET=

# --- Phase 3: data protection ---
# Fernet key for PII-at-rest encryption (AES-128-CBC + HMAC-SHA256).
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Unset = encryption disabled (NOT recommended in production).
# WARNING: Losing this key makes all existing candidate rows PERMANENTLY
# UNDECRYPTABLE. Store it in a secrets manager, not in this file.
RFE_ENCRYPTION_KEY=

# Auto-purge candidates older than N days (cascades evaluations + feedback).
# 0 disables purge. Default 365. Trigger via POST /admin/purge (admin role).
# Candidates with no created_at (legacy rows) are never purged.
RFE_RETENTION_DAYS=365

# --- Phase 3: web UI ---
# Serve the bundled single-page UI at GET / (and /static/*). Set to 0 to disable.
RFE_SERVE_UI=1

# --- Phase 5: TLS ---
# Domain for Caddy TLS termination.
# localhost (default): Caddy issues a self-signed certificate (dev / LAN).
# Real domain (e.g. rfe.example.com): Caddy provisions a Let's Encrypt cert
# automatically — port 443 must be reachable from the internet for ACME.
RFE_DOMAIN=localhost
